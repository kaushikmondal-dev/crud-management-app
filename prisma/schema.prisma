// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "sqlite"
}

model UserTable {
  userId     String @id @default(uuid())
  userName   String
  userEmail  String @unique
  userGender String
  userPhNo   String
}
